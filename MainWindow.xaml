<Window x:Class="NotchNookNative.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="NotchNook" Height="250" Width="500"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        Topmost="True" ResizeMode="NoResize" ShowInTaskbar="False"
        Icon="icon.png"
        TextOptions.TextFormattingMode="Display">
    <Window.Resources>
        <!-- Modern Minimal ScrollBar Style -->
        <Style x:Key="ModernScrollThumb" TargetType="Thumb">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Thumb">
                        <Border x:Name="thumbBorder" CornerRadius="3" Background="#777777" Opacity="0.2" Margin="2,0,0,0" />
                        <ControlTemplate.Triggers>
                            <EventTrigger RoutedEvent="MouseEnter">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="thumbBorder" Storyboard.TargetProperty="Opacity" To="0.8" Duration="0:0:0.15" />
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                            <EventTrigger RoutedEvent="MouseLeave">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="thumbBorder" Storyboard.TargetProperty="Opacity" To="0.2" Duration="0:0:0.3" />
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <Style TargetType="ScrollBar">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Width" Value="8"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid>
                            <Border Background="Transparent" />
                            <Track x:Name="PART_Track" IsDirectionReversed="true">
                                <Track.Thumb>
                                    <Thumb Style="{StaticResource ModernScrollThumb}" />
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- The XAML GPU-Accelerated Hardware Storyboards -->
        <Storyboard x:Key="ExpandStoryboard">
            <DoubleAnimation Storyboard.TargetName="IslandBackground" Storyboard.TargetProperty="Width" To="480" Duration="0:0:0.4">
                <DoubleAnimation.EasingFunction>
                    <BackEase EasingMode="EaseOut" Amplitude="0.3"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="IslandBackground" Storyboard.TargetProperty="Height" To="220" Duration="0:0:0.4">
                <DoubleAnimation.EasingFunction>
                    <BackEase EasingMode="EaseOut" Amplitude="0.3"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="ExpandedContent" Storyboard.TargetProperty="Opacity" To="1" Duration="0:0:0.4" BeginTime="0:0:0.2" />
            <DoubleAnimation Storyboard.TargetName="ExpandedContentTransform" Storyboard.TargetProperty="Y" From="-15" To="0" Duration="0:0:0.4" BeginTime="0:0:0.2">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="GreenLight" Storyboard.TargetProperty="Opacity" To="0" Duration="0:0:0.2" />
        </Storyboard>
        
        <Storyboard x:Key="CollapseStoryboard">
            <DoubleAnimation Storyboard.TargetName="IslandBackground" Storyboard.TargetProperty="Width" To="120" Duration="0:0:0.4">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="IslandBackground" Storyboard.TargetProperty="Height" To="35" Duration="0:0:0.4">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="ExpandedContent" Storyboard.TargetProperty="Opacity" To="0" Duration="0:0:0.2" />
            <DoubleAnimation Storyboard.TargetName="ExpandedContentTransform" Storyboard.TargetProperty="Y" To="-15" Duration="0:0:0.2" />
            <DoubleAnimation Storyboard.TargetName="GreenLight" Storyboard.TargetProperty="Opacity" To="1" Duration="0:0:0.2" BeginTime="0:0:0.2"/>
        </Storyboard>

        <Storyboard x:Key="PlayingEQAnimation" RepeatBehavior="Forever" Timeline.DesiredFrameRate="24">
            <DoubleAnimation Storyboard.TargetName="EqBar1" Storyboard.TargetProperty="Y" From="16" To="6" Duration="0:0:0.3" AutoReverse="True"/>
            <DoubleAnimation Storyboard.TargetName="EqBar2" Storyboard.TargetProperty="Y" From="4" To="14" Duration="0:0:0.4" AutoReverse="True"/>
            <DoubleAnimation Storyboard.TargetName="EqBar3" Storyboard.TargetProperty="Y" From="12" To="4" Duration="0:0:0.35" AutoReverse="True"/>
            <DoubleAnimation Storyboard.TargetName="EqBar4" Storyboard.TargetProperty="Y" From="2" To="16" Duration="0:0:0.45" AutoReverse="True"/>
        </Storyboard>

        <!-- Removed ChargeGlowAnimation pending design feedback -->
        
        <!-- Button Hover Animations -->
        <Style TargetType="Button" x:Key="AnimatedButton">
            <Setter Property="Background" Value="#01000000"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
            <Setter Property="Opacity" Value="0.7"/>
            <Setter Property="RenderTransform">
                <Setter.Value>
                    <ScaleTransform ScaleX="1" ScaleY="1"/>
                </Setter.Value>
            </Setter>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <EventTrigger RoutedEvent="MouseEnter">
                    <BeginStoryboard>
                        <Storyboard>
                            <DoubleAnimation Storyboard.TargetProperty="RenderTransform.ScaleX" To="1.2" Duration="0:0:0.15">
                                <DoubleAnimation.EasingFunction><QuadraticEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                            </DoubleAnimation>
                            <DoubleAnimation Storyboard.TargetProperty="RenderTransform.ScaleY" To="1.2" Duration="0:0:0.15">
                                <DoubleAnimation.EasingFunction><QuadraticEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                            </DoubleAnimation>
                            <DoubleAnimation Storyboard.TargetProperty="Opacity" To="1.0" Duration="0:0:0.15"/>
                        </Storyboard>
                    </BeginStoryboard>
                </EventTrigger>
                <EventTrigger RoutedEvent="MouseLeave">
                    <BeginStoryboard>
                        <Storyboard>
                            <DoubleAnimation Storyboard.TargetProperty="RenderTransform.ScaleX" To="1.0" Duration="0:0:0.15"/>
                            <DoubleAnimation Storyboard.TargetProperty="RenderTransform.ScaleY" To="1.0" Duration="0:0:0.15"/>
                            <DoubleAnimation Storyboard.TargetProperty="Opacity" To="0.7" Duration="0:0:0.15"/>
                        </Storyboard>
                    </BeginStoryboard>
                </EventTrigger>
            </Style.Triggers>
        </Style>

        <!-- Custom Circle Volume Slider Style -->
        <ControlTemplate x:Key="SliderRepeatButton" TargetType="RepeatButton">
            <Border Background="Transparent"/>
        </ControlTemplate>

        <Style x:Key="SleekSlider" TargetType="Slider">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Slider">
                        <Grid VerticalAlignment="Center">
                            <Border Height="4" Background="#333" CornerRadius="2" VerticalAlignment="Center"/>
                            <Track x:Name="PART_Track">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="{x:Static Slider.DecreaseLarge}" Template="{StaticResource SliderRepeatButton}"/>
                                </Track.DecreaseRepeatButton>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="{x:Static Slider.IncreaseLarge}" Template="{StaticResource SliderRepeatButton}"/>
                                </Track.IncreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb>
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Ellipse Width="12" Height="12" Fill="White" Cursor="Hand"/>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <!-- The Main Island Physics Layer -->
        <Border x:Name="IslandBackground" 
                Width="120" Height="35" 
                CornerRadius="17.5"
                BorderThickness="0"
                Background="#181818"
                HorizontalAlignment="Center" VerticalAlignment="Top"
                Margin="0,20,0,0"
                Cursor="Hand" MouseEnter="IslandBackground_MouseEnter" MouseLeave="IslandBackground_MouseLeave">
            
            <Grid>
                <!-- PREMIUM BACKGROUND COMBINED -->
                <Grid>
                    <!-- 1. Studio Lighting -->
                    <Border CornerRadius="17.5" IsHitTestVisible="False">
                        <Border.Background>
                            <RadialGradientBrush Center="0.5,0" GradientOrigin="0.5,0" RadiusX="0.8" RadiusY="1.0">
                                <GradientStop Color="#2A2A2A" Offset="0.0"/>
                                <GradientStop Color="#050505" Offset="1.0"/>
                            </RadialGradientBrush>
                        </Border.Background>
                    </Border>
                    <!-- 2. Matte Noise Texture -->
                    <Border CornerRadius="17.5" IsHitTestVisible="False" Opacity="0.03">
                        <Border.Background>
                            <DrawingBrush Viewport="0,0,2,2" ViewportUnits="Absolute" TileMode="Tile">
                                <DrawingBrush.Drawing>
                                    <DrawingGroup>
                                        <GeometryDrawing Brush="White">
                                            <GeometryDrawing.Geometry>
                                                <GeometryGroup><RectangleGeometry Rect="0,0,1,1"/><RectangleGeometry Rect="1,1,1,1"/></GeometryGroup>
                                            </GeometryDrawing.Geometry>
                                        </GeometryDrawing>
                                        <GeometryDrawing Brush="Black">
                                            <GeometryDrawing.Geometry>
                                                <GeometryGroup><RectangleGeometry Rect="1,0,1,1"/><RectangleGeometry Rect="0,1,1,1"/></GeometryGroup>
                                            </GeometryDrawing.Geometry>
                                        </GeometryDrawing>
                                    </DrawingGroup>
                                </DrawingBrush.Drawing>
                            </DrawingBrush>
                        </Border.Background>
                    </Border>
                    <!-- 3. Glass Edge Bevel -->
                    <Border CornerRadius="17.5" IsHitTestVisible="False" BorderBrush="#25FFFFFF" BorderThickness="1,1,0,0"/>
                    <Border CornerRadius="17.5" IsHitTestVisible="False" BorderBrush="#50000000" BorderThickness="0,0,1,1"/>
                </Grid>

                <!-- Green Light Indicator -->
                <Ellipse x:Name="GreenLight" Width="8" Height="8" Fill="#00FF41" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,18,0">
                    <Ellipse.Effect>
                        <DropShadowEffect Color="#00FF41" BlurRadius="12" ShadowDepth="0" Opacity="0.8"/>
                    </Ellipse.Effect>
                </Ellipse>

                <Grid x:Name="ExpandedContent" Opacity="0" Margin="16" CacheMode="BitmapCache">
                    <Grid.RenderTransform>
                        <TranslateTransform x:Name="ExpandedContentTransform" Y="-15"/>
                    </Grid.RenderTransform>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                
                <!-- Top Tabs -->
                <Grid Grid.Row="0" Margin="5,0,5,8">
                    <StackPanel Orientation="Horizontal" x:Name="TabHeaders" HorizontalAlignment="Left" VerticalAlignment="Center">
                        <TextBlock x:Name="TabNook" Text="📌 Nook" Foreground="White" FontSize="14" FontWeight="Bold" Margin="0,0,20,0" Cursor="Hand" MouseLeftButtonDown="TabNook_Click" Padding="4" RenderTransformOrigin="0.5,0.5">
                            <TextBlock.Effect>
                                <DropShadowEffect Color="White" BlurRadius="4" ShadowDepth="0" Opacity="0.4"/>
                            </TextBlock.Effect>
                            <TextBlock.RenderTransform>
                                <ScaleTransform x:Name="TabNookScale" ScaleX="1.15" ScaleY="1.15"/>
                            </TextBlock.RenderTransform>
                        </TextBlock>
                        <TextBlock x:Name="TabClipboard" Text="📋 Clipboard" Foreground="#888888" FontSize="14" FontWeight="Bold" Cursor="Hand" MouseLeftButtonDown="TabClipboard_Click" Padding="4" RenderTransformOrigin="0.5,0.5">
                            <TextBlock.RenderTransform>
                                <ScaleTransform x:Name="TabClipboardScale" ScaleX="1.0" ScaleY="1.0"/>
                            </TextBlock.RenderTransform>
                        </TextBlock>
                    </StackPanel>
                    
                    <!-- Update Available Button (Hidden by default) -->
                    <Button x:Name="UpdateButton" Visibility="Collapsed" HorizontalAlignment="Right" VerticalAlignment="Center" Style="{StaticResource AnimatedButton}" Click="UpdateButton_Click">
                        <Border Background="#1a331a" BorderBrush="#00FF41" BorderThickness="1" CornerRadius="4" Padding="6,2">
                            <TextBlock Text="↓ UPDATE" Foreground="#00FF41" FontSize="10" FontWeight="Bold"/>
                        </Border>
                    </Button>
                </Grid>

                <!-- Horizontal Divider -->
                <Border Grid.Row="1" Height="1" Background="#333" Margin="0,0,0,12"/>

                <!-- Dual Pane Layout (Dashboard View) -->
                <Grid Grid.Row="2" x:Name="DashboardView">
                    <Grid.RenderTransform>
                        <TranslateTransform x:Name="DashboardTransform" X="0"/>
                    </Grid.RenderTransform>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="1"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Left Side: Music Player -->
                    <Grid Grid.Column="0" Margin="0,0,15,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        
                        <Grid Grid.Row="0" Margin="0,15,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            
                            <!-- Column 0: Album Art -->
                            <Grid Grid.Column="0" Width="70" Height="70" VerticalAlignment="Top" Margin="0,8,15,0">
                                <Border CornerRadius="10" BorderBrush="#333" BorderThickness="1" ClipToBounds="True">
                                    <Grid>
                                        <Border>
                                            <Border.Background>
                                                <ImageBrush x:Name="AlbumArtImage" Stretch="UniformToFill"/>
                                            </Border.Background>
                                        </Border>
                                        
                                        <!-- Animated Playing Overlay -->
                                        <Border x:Name="PlayingOverlay" Background="#90000000" Visibility="Collapsed">
                                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center" Height="20">
                                                <Border ClipToBounds="True" Height="20" Width="4" Margin="1.5,0">
                                                    <Rectangle Width="4" Height="20" Fill="White" RadiusX="2" RadiusY="2" VerticalAlignment="Top">
                                                        <Rectangle.RenderTransform><TranslateTransform x:Name="EqBar1" Y="16"/></Rectangle.RenderTransform>
                                                    </Rectangle>
                                                </Border>
                                                <Border ClipToBounds="True" Height="20" Width="4" Margin="1.5,0">
                                                    <Rectangle Width="4" Height="20" Fill="White" RadiusX="2" RadiusY="2" VerticalAlignment="Top">
                                                        <Rectangle.RenderTransform><TranslateTransform x:Name="EqBar2" Y="4"/></Rectangle.RenderTransform>
                                                    </Rectangle>
                                                </Border>
                                                <Border ClipToBounds="True" Height="20" Width="4" Margin="1.5,0">
                                                    <Rectangle Width="4" Height="20" Fill="White" RadiusX="2" RadiusY="2" VerticalAlignment="Top">
                                                        <Rectangle.RenderTransform><TranslateTransform x:Name="EqBar3" Y="12"/></Rectangle.RenderTransform>
                                                    </Rectangle>
                                                </Border>
                                                <Border ClipToBounds="True" Height="20" Width="4" Margin="1.5,0">
                                                    <Rectangle Width="4" Height="20" Fill="White" RadiusX="2" RadiusY="2" VerticalAlignment="Top">
                                                        <Rectangle.RenderTransform><TranslateTransform x:Name="EqBar4" Y="2"/></Rectangle.RenderTransform>
                                                    </Rectangle>
                                                </Border>
                                            </StackPanel>
                                        </Border>
                                    </Grid>
                                </Border>
                                <!-- Apple Music Red Badge -->
                                <Border Width="18" Height="18" CornerRadius="9" Background="#FA243C" HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,-5,-5">
                                    <TextBlock Text="🎵" Foreground="White" FontSize="10" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </Grid>
                            
                            <!-- Column 1: Music Info & Controls -->
                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <!-- Track Info -->
                                <TextBlock x:Name="TrackTitle" Text="Not playing" Foreground="White" FontSize="16" FontWeight="Bold" TextTrimming="CharacterEllipsis" TextWrapping="NoWrap"/>
                                <TextBlock x:Name="TrackArtist" Text="..." Foreground="#aaa" FontSize="13" Margin="0,2,0,0" TextTrimming="CharacterEllipsis" TextWrapping="NoWrap"/>
                                
                                <!-- Media Controls -->
                                <StackPanel Orientation="Horizontal" Margin="0,10,0,0" HorizontalAlignment="Left">
                                    <Button Style="{StaticResource AnimatedButton}" Content="&#xE892;" FontFamily="Segoe MDL2 Assets" Width="30" Height="30" Foreground="#ccc" FontSize="16" Click="Prev_Click"/>
                                    <Button x:Name="PlayPauseButton" Style="{StaticResource AnimatedButton}" Content="&#xE768;" FontFamily="Segoe MDL2 Assets" Width="40" Height="30" Foreground="#fff" FontSize="18" Margin="8,0" Click="PlayPause_Click"/>
                                    <Button Style="{StaticResource AnimatedButton}" Content="&#xE893;" FontFamily="Segoe MDL2 Assets" Width="30" Height="30" Foreground="#fff" FontSize="16" Click="Next_Click"/>
                                </StackPanel>
                            </StackPanel>
                        </Grid>

                        <!-- Volume Slider -->
                        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,10,0,0" HorizontalAlignment="Left">
                            <Button x:Name="MuteButton" Background="Transparent" BorderThickness="0" Padding="0" Margin="0,0,10,0" Cursor="Hand" Click="MuteButton_Click">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="Transparent">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Button.Template>
                                <TextBlock x:Name="VolumeIcon" Text="&#xE995;" Width="16" TextAlignment="Center" FontFamily="Segoe MDL2 Assets" Foreground="White" FontSize="14" VerticalAlignment="Center"/>
                            </Button>
                            <Slider x:Name="VolumeSlider" Width="180" VerticalAlignment="Center" Minimum="0" Maximum="100" Value="50" IsMoveToPointEnabled="True" Style="{StaticResource SleekSlider}" ValueChanged="VolumeSlider_ValueChanged"/>
                        </StackPanel>
                    </Grid>

                    <!-- Vertical Divider -->
                    <Border Grid.Column="1" Background="#222" Margin="0,10,0,10"/>

                    <!-- Right Pane: Calendar & Widgets -->
                    <StackPanel Grid.Column="2" Margin="15,0,0,0">
                        <!-- Calendar Header -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,15" VerticalAlignment="Bottom">
                            <TextBlock x:Name="MonthText" Text="---" Foreground="White" FontWeight="Black" FontSize="26" VerticalAlignment="Center" Margin="0,0,15,0"/>
                            
                            <!-- Days List -->
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <StackPanel Margin="0,0,10,0">
                                    <TextBlock x:Name="Day1Name" Text="---" FontSize="9" FontWeight="Bold" Foreground="#4da6ff" HorizontalAlignment="Center" Margin="0,0,0,2"/>
                                    <TextBlock x:Name="Day1Num" Text="--" FontSize="14" FontWeight="Bold" Foreground="#4da6ff" HorizontalAlignment="Center"/>
                                </StackPanel>
                                <StackPanel Margin="0,0,10,0" Opacity="0.5">
                                    <TextBlock x:Name="Day2Name" Text="---" FontSize="9" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center" Margin="0,0,0,2"/>
                                    <TextBlock x:Name="Day2Num" Text="--" FontSize="14" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center"/>
                                </StackPanel>
                                <StackPanel Margin="0,0,10,0" Opacity="0.5">
                                    <TextBlock x:Name="Day3Name" Text="---" FontSize="9" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center" Margin="0,0,0,2"/>
                                    <TextBlock x:Name="Day3Num" Text="--" FontSize="14" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center"/>
                                </StackPanel>
                                <StackPanel Margin="0,0,0,0" Opacity="0.5">
                                    <TextBlock x:Name="Day4Name" Text="---" FontSize="9" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center" Margin="0,0,0,2"/>
                                    <TextBlock x:Name="Day4Num" Text="--" FontSize="14" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center"/>
                                </StackPanel>
                            </StackPanel>
                        </StackPanel>
                        
                        <!-- System Stats -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                            <Border Background="#111" BorderBrush="#222" BorderThickness="1" CornerRadius="8" Padding="12,8" Margin="0,0,10,0">
                                <TextBlock FontSize="14" FontWeight="Heavy">
                                    <Run Foreground="#00FF41" Text="🔋 "/>
                                    <Run x:Name="BattTextRun" Foreground="White" Text="80%"/>
                                </TextBlock>
                            </Border>
                            <Border Background="#111" BorderBrush="#222" BorderThickness="1" CornerRadius="8" Padding="12,8">
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <Image x:Name="WeatherImageIcon" Width="20" Height="20" Margin="0,0,6,0" RenderOptions.BitmapScalingMode="HighQuality"/>
                                    <TextBlock x:Name="WeatherTempRun" Text="21°" Foreground="White" FontSize="14" FontWeight="Bold" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                        
                        <!-- Quick Apps -->
                        <WrapPanel>
                            <Border Background="#111" BorderBrush="#222" BorderThickness="1" CornerRadius="8" Width="32" Height="32" Margin="0,0,10,10"><Button Style="{StaticResource AnimatedButton}" FontFamily="Segoe UI Emoji" Content="🧮" Foreground="#ffd699" FontSize="16" Tag="calc" Click="App_Click"/></Border>
                            <Border Background="#111" BorderBrush="#222" BorderThickness="1" CornerRadius="8" Width="32" Height="32" Margin="0,0,10,10"><Button Style="{StaticResource AnimatedButton}" FontFamily="Segoe UI Emoji" Content="📝" Foreground="#ffb3ff" FontSize="16" Tag="notepad" Click="App_Click"/></Border>
                            <Border Background="#111" BorderBrush="#222" BorderThickness="1" CornerRadius="8" Width="32" Height="32" Margin="0,0,10,10"><Button Style="{StaticResource AnimatedButton}" FontFamily="Segoe UI Emoji" Content="📁" Foreground="#ffff99" FontSize="16" Tag="explorer" Click="App_Click"/></Border>
                            <Border Background="#111" BorderBrush="#222" BorderThickness="1" CornerRadius="8" Width="32" Height="32" Margin="0,0,10,10"><Button Style="{StaticResource AnimatedButton}" FontFamily="Segoe UI Emoji" Content="🌐" Foreground="#80dfff" FontSize="16" Tag="browser" Click="App_Click"/></Border>
                            <Border Background="#111" BorderBrush="#222" BorderThickness="1" CornerRadius="8" Width="32" Height="32" Margin="0,0,0,10"><Button Style="{StaticResource AnimatedButton}" FontFamily="Segoe UI Emoji" Content="🗑️" Foreground="#ff8080" FontSize="16" Tag="recycle" Click="App_Click"/></Border>
                        </WrapPanel>
                    </StackPanel>
                </Grid>

                <!-- Clipboard View (Hidden by default) -->
                <Grid Grid.Row="2" x:Name="ClipboardView" Visibility="Collapsed" Margin="0,10,0,0">
                    <Grid.RenderTransform>
                        <TranslateTransform x:Name="ClipboardTransform" X="20"/>
                    </Grid.RenderTransform>
                    
                    <TextBlock x:Name="EmptyClipboardMessage" Text="Clipboard is empty" Foreground="#555" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="14" FontWeight="SemiBold" Visibility="Visible"/>
                    
                    <ListBox x:Name="ClipboardList" SelectionChanged="ClipboardList_SelectionChanged" ScrollViewer.VerticalScrollBarVisibility="Auto" ScrollViewer.HorizontalScrollBarVisibility="Disabled" ScrollViewer.CanContentScroll="True" VirtualizingPanel.ScrollUnit="Pixel" VirtualizingPanel.IsVirtualizing="True" VirtualizingPanel.VirtualizationMode="Recycling" CacheMode="BitmapCache" Background="Transparent" Foreground="White" BorderThickness="0" FontFamily="Segoe UI" FontSize="13" HorizontalContentAlignment="Stretch">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding}" TextTrimming="CharacterEllipsis" />
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="Padding" Value="10"/>
                                <Setter Property="Margin" Value="0,0,0,5"/>
                                <Setter Property="Background" Value="#222"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ListBoxItem">
                                            <Border Background="{TemplateBinding Background}" CornerRadius="6" BorderBrush="#333" BorderThickness="1">
                                                <ContentPresenter Margin="{TemplateBinding Padding}"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ListBox.ItemContainerStyle>
                    </ListBox>
                </Grid>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Window>
